{
  "name": "resume-generator",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "vite build && electron-builder --mac --publish=never"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "build": {
    "appId": "com.antigravity.resume-generator",
    "productName": "智能简历生成器",
    "directories": {
      "output": "dist-desktop"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "publish": {
        "provider": "github",
        "owner": "zyf2492313716-cloud",
        "repo": "resume-generator",
        "releaseType": "release"
      }
    },
    "dmg": {
      "iconSize": 120,
      "iconTextSize": 14,
      "background": "build/background.png",
      "title": "智能简历生成器安装盘",
      "contents": [
        {
          "x": 140,
          "y": 200,
          "type": "file"
        },
        {
          "x": 480,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 660,
        "height": 440
      }
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/utils",
        "to": "utils"
      }
    ],
    "asar": false
  }
}
